# ─── API Keys ────────────────────────────────────────────────────────────────
# Get your Massive API key from https://massive.com/docs
MASSIVE_API_KEY="your massive api key here"

# Get your CoinGecko API key from https://www.coingecko.com/en/api
# Leave empty to use the free tier (rate limited)
COINGECKO_API_KEY="your coingecko api key here"

# ─── GCP Configuration ──────────────────────────────────────────────────────
GCP_PROJECT_ID="your gcp project id here"
GCS_BUCKET="your gcs bucket name here"
BQ_LOCATION="location of your bigquery dataset here, eg: US"

# Path to gcloud config directory (for ADC)
# Default: ~/.config/gcloud
GOOGLE_APPLICATION_CREDENTIALS_DIR=~/.config/gcloud

# ─── Airflow Configuration ───────────────────────────────────────────────────
AIRFLOW_UID=50000
